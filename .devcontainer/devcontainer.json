{
  "name": "Reflecta Daily - Flutter Dev",
  "build": { "dockerfile": "Dockerfile" },
  "features": {
    "ghcr.io/devcontainers/features/node:1": { "version": "20" }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "Dart-Code.dart-code",
        "Dart-Code.flutter",
        "nash.awesome-flutter-snippets",
        "firebase-tools.firebase-tools",
        "PKief.material-icon-theme"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "dart.flutterSdkPath": "/flutter",
        "dart.lineLength": 100
      }
    }
  },
  "postCreateCommand": "flutter pub get && firebase --version",
  "remoteEnv": { "PATH": "${containerEnv:PATH}:/flutter/bin" },
  "forwardPorts": [8080, 5000, 9099, 4000],
  "portsAttributes": {
    "8080": { "label": "Flutter Web" },
    "5000": { "label": "Firebase Hosting" },
    "9099": { "label": "Firebase Auth Emulator" },
    "4000": { "label": "Firebase Emulator UI" }
  }
}
